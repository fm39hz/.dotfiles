{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "lsp-enforcement@git+https://github.com/fm39hz/open-code-lsp-enforcement.git",
    "ponytails@git+https://github.com/DietrichGebert/ponytail/.opencode/plugins/ponytail.mjs"
  ],
  "lsp": {
    "roslyn": {
      "extensions": [
        "cs"
      ],
      "command": [
        "/home/fm39hz/.local/share/nvim/mason/bin/roslyn"
      ]
    }
  },
  "permission": {
    "grep": "ask",
    "glob": "ask",
    "bash": "ask",
  },
  "mcp": {
    "docshark": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "docshark",
        "start",
        "--stdio"
      ],
      "enabled": true
    },
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
  },
  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "sk_9router"
      },
      "models": {
        "ag/claude-sonnet-4-6": {
          "name": "ag/claude-sonnet-4-6"
        },
        "ag/claude-opus-4-6-thinking": {
          "name": "ag/claude-opus-4-6-thinking"
        },
        "gh/claude-opus-4.5": {
          "name": "gh/claude-opus-4.5"
        },
        "kr/claude-sonnet-4.5": {
          "name": "kr/claude-sonnet-4.5"
        },
        "coder": {
          "name": "coder"
        },
        "daily-worker": {
          "name": "daily-worker"
        },
        "context-holder": {
          "name": "context-holder"
        },
      }
    }
  },
  "model": "daily-worker",
  "agent": {
    "explorer": {
      "description": "Fast explorer subagent for codebase exploration",
      "mode": "subagent",
      "model": "daily-worker"
    }
  }
}
