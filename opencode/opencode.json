{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "godot": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@coding-solo/godot-mcp"
      ],
      "enabled": true,
      "environment": {
        "DEBUG": "true"
      }
    }
  },
  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "sk_9router"
      },
      "models": {
        "qw/coder-model": {
          "name": "qw/coder-model"
        },
        "qw/qwen3-coder-plus": {
          "name": "qw/qwen3-coder-plus"
        },
        "ag/claude-sonnet-4-6": {
          "name": "ag/claude-sonnet-4-6"
        },
        "ag/claude-opus-4-6-thinking": {
          "name": "ag/claude-opus-4-6-thinking"
        },
        "ag/gemini-3.1-pro-low": {
          "name": "ag/gemini-3.1-pro-low"
        },
        "gh/claude-opus-4.5": {
          "name": "gh/claude-opus-4.5"
        },
        "daily-combo": {
          "name": "daily-combo"
        }
      }
    }
  },
  "model": "9router/ag/claude-sonnet-4-6",
  "agent": {
    "explorer": {
      "description": "Fast explorer subagent for codebase exploration",
      "mode": "subagent",
      "model": "9router/daily-combo"
    }
  }
}