{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "godot": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "@coding-solo/godot-mcp"
      ],
      "enabled": true,
      "environment": {
        "DEBUG": "true"
      }
    }
  },
  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "sk_9router"
      },
      "models": {
        "qw/coder-model": {
          "name": "qw/coder-model"
        },
        "qw/qwen3-coder-plus": {
          "name": "qw/qwen3-coder-plus"
        },
        "ag/claude-sonnet-4-6": {
          "name": "ag/claude-sonnet-4-6"
        },
        "ag/claude-opus-4-6-thinking": {
          "name": "ag/claude-opus-4-6-thinking"
        },
        "ag/gemini-3.1-pro-low": {
          "name": "ag/gemini-3.1-pro-low"
        },
        "gh/claude-opus-4.5": {
          "name": "gh/claude-opus-4.5"
        },
        "daily-combo": {
          "name": "daily-combo"
        },
        "claude": {
          "name": "claude"
        },
        "cu/default": {
          "name": "cu/default"
        },
        "cu/claude-4.5-opus-high-thinking": {
          "name": "cu/claude-4.5-opus-high-thinking"
        },
        "cu/claude-4.5-sonnet": {
          "name": "cu/claude-4.5-sonnet"
        },
        "cx/gpt-5.3-codex-xhigh": {
          "name": "cx/gpt-5.3-codex-xhigh"
        },
        "cx/gpt-5.4": {
          "name": "cx/gpt-5.4"
        }
      }
    }
  },
  "model": "9router/cx/gpt-5.4",
  "agent": {
    "explorer": {
      "description": "Fast explorer subagent for codebase exploration",
      "mode": "subagent",
      "model": "9router/ag/gemini-3.1-pro-low"
    }
  }
}
