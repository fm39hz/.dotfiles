{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "lsp-enforcement@git+https://github.com/fm39hz/open-code-lsp-enforcement.git",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-firecrawl"
  ],
  "lsp": {
    "roslyn": {
      "extensions": [
        "cs"
      ],
      "command": [
        "/home/fm39hz/.local/share/nvim/mason/bin/roslyn"
      ]
    }
  },
  "mcp": {
    "docshark": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "docshark",
        "start",
        "--stdio"
      ],
      "enabled": true
    },
  },
  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "sk_9router"
      },
      "models": {
        "ag/claude-sonnet-4-6": {
          "name": "ag/claude-sonnet-4-6"
        },
        "ag/claude-opus-4-6-thinking": {
          "name": "ag/claude-opus-4-6-thinking"
        },
        "gh/claude-opus-4.5": {
          "name": "gh/claude-opus-4.5"
        },
        "cu/default": {
          "name": "cu/default"
        },
        "cu/claude-4.5-opus-high-thinking": {
          "name": "cu/claude-4.5-opus-high-thinking"
        },
        "cu/claude-4.5-sonnet": {
          "name": "cu/claude-4.5-sonnet"
        },
        "cx/gpt-5.3-codex-xhigh": {
          "name": "cx/gpt-5.3-codex-xhigh"
        },
        "cx/gpt-5.4": {
          "name": "cx/gpt-5.4"
        },
        "ag/gemini-3.1-pro-high": {
          "name": "ag/gemini-3.1-pro-high"
        },
        "kr/claude-sonnet-4.5": {
          "name": "kr/claude-sonnet-4.5"
        },
        "coder": {
          "name": "coder"
        },
        "daily-worker": {
          "name": "daily-worker"
        },
        "context-holder": {
          "name": "context-holder"
        },
        "reasoner": {
          "name": "reasoner"
        },
        "ds/deepseek-reasoner": {
          "name": "ds/deepseek-reasoner"
        },
        "glm/glm-5.1": {
          "name": "glm/glm-5.1"
        }
      }
    }
  },
  "model": "9router/daily-worker",
  "agent": {
    "explorer": {
      "description": "Fast explorer subagent for codebase exploration",
      "mode": "subagent",
      "model": "9router/daily-worker"
    }
  }
}
