{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "lsp-enforcement@git+https://github.com/fm39hz/open-code-lsp-enforcement.git",
    "ponytails@git+https://github.com/DietrichGebert/ponytail/.opencode/plugins/ponytail.mjs"
  ],
  "lsp": {
    "roslyn": {
      "extensions": [
        "cs"
      ],
      "command": [
        "/home/fm39hz/.local/share/nvim/mason/bin/roslyn"
      ]
    }
  },
  "permission": {
    "grep": "ask",
    "glob": "ask",
    "bash": "ask",
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
  },
  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:20128/v1",
        "apiKey": "sk_9router"
      },
      "models": {
        "coder": {
          "name": "coder"
        },
        "daily-worker": {
          "name": "daily-worker"
        },
        "mimo": {
          "name": "mimo"
        },
        "qwen": {
          "name": "qwen"
        },
        "deepseek": {
          "name": "deepseek"
        },
        "claude": {
          "name": "claude"
        },
        "kimi": {
          "name": "kimi"
        },
        "glm": {
          "name": "glm"
        },
        "minimax": {
          "name": "minimax"
        },
      }
    }
  },
  "model": "daily-worker",
  "agent": {
    "explorer": {
      "description": "Fast explorer subagent for codebase exploration",
      "mode": "subagent",
      "model": "9router/minimax"
    }
  }
}
