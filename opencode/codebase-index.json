{
  "embeddingProvider": "custom",
  "scope": "project",
  "include": [
    "**/*.{ts,js,py,go,rs,cs,csproj,slnx,json}"
  ],
  "customProvider": {
    "baseUrl": "http://localhost:20128/v1",
    "model": "openrouter/qwen/qwen3-embedding-8b",
    "dimensions": 1024,
    "apiKey": "sk_9router",
    "maxTokens": 8192,
    "timeoutMs": 30000,
    "concurrency": 3,
    "requestIntervalMs": 1000,
    "maxBatchSize": 64
  },
  "exclude": [
    "**/node_modules/**",
    "**/addons/**",
    "**/obj/**",
    "**/bin/**"
  ],
  "additionalInclude": [
    "**/*.{txt,html,htm}",
    "**/*.pdf"
  ],
  "indexing": {
    "autoIndex": true,
    "watchFiles": true,
    "maxFileSize": 1048576,
    "maxChunksPerFile": 50,
    "semanticOnly": true,
    "maxDepth": 10
  },
  "search": {
    "maxResults": 7,
    "minScore": 0.3,
    "hybridWeight": 0.4
  },
  "reranker": {
    "enabled": true,
    "provider": "auto",
    "model": "gemini/gemini-embedding-2-preview",
    "baseUrl": "http://localhost:20128/v1/embeddings",
    "topN": 15,
    "timeoutMs": 10000
  },
  "debug": {
    "enabled": true
  }
}
